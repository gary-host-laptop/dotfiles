# appearance
background = #1e1e1e
foreground = #e3e5e5
window-padding-x = 12
window-padding-y = 8
gtk-titlebar-style = tabs
window-theme = ghostty
gtk-custom-css = ~/.config/ghostty/custom.css

# font
font-family = FiraCode Nerd Font
font-size = 11

# tabs
gtk-tabs-location = top

# cursor
cursor-style = bar
cursor-style-blink = true

# misc
scrollback-limit = 10000
copy-on-select = true
